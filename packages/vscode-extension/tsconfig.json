{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "out",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "es2020",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020"]
  },
  "include": ["src", "media/**/*.ts", "media/**/*.tsx"]
}
